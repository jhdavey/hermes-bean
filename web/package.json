{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "benchmark:voice:browser": "node tests/browser/voice-v2-benchmark.mjs",
        "dev": "vite",
        "preflight:voice:production": "node tests/browser/voice-v2-production-preflight.mjs",
        "test:voice": "node --test tests/js/*.test.mjs",
        "test:voice:all": "npm run test:voice && npm run test:voice:browser",
        "test:voice:browser": "playwright test --config=playwright.voice.config.mjs"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^3.1",
        "playwright": "^1.60.0",
        "tailwindcss": "^4.0.0",
        "vite": "^8.0.0"
    }
}
